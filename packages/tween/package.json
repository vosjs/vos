{
  "name": "@vosjs/tween",
  "version": "0.3.0",
  "description": "Records a GSAP-dialect timeline into a structured, per-element tween IR (TweenSpec/TimelineDoc) for extraction and editing — a recording facade that delegates 1:1 to a real tween backend while capturing the animation as data. For the vos programmatic video engine.",
  "type": "module",
  "license": "MIT",
  "author": "vosso",
  "homepage": "https://vos.so/engine",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vosjs/vos.git",
    "directory": "packages/tween"
  },
  "bugs": {
    "url": "https://github.com/vosjs/vos/issues"
  },
  "keywords": [
    "vos",
    "gsap",
    "timeline",
    "tween",
    "animation",
    "recorder",
    "extraction",
    "keyframes",
    "deterministic",
    "video",
    "editor"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@vosjs/timeline": "^0.2.0"
  },
  "devDependencies": {
    "gsap": "^3.14.2",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
