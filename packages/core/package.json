{
  "name": "@vosjs/core",
  "version": "0.4.0",
  "description": "The vos engine — the open visual operating system: compile a function into deterministic, resolution-independent, mixed-media (Three.js / GSAP / 2D / HTML / video) video.",
  "type": "module",
  "license": "MIT",
  "author": "vosso",
  "homepage": "https://github.com/vosjs/vos#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vosjs/vos.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/vosjs/vos/issues"
  },
  "keywords": [
    "vos",
    "three",
    "threejs",
    "gsap",
    "animation",
    "webgl",
    "generative",
    "declarative",
    "compiler"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/types/index.js"
    },
    "./compiler": {
      "types": "./dist/compiler/index.d.ts",
      "import": "./dist/compiler/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./addons": {
      "types": "./dist/addons/index.d.ts",
      "import": "./dist/addons/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    },
    "./extract": {
      "types": "./dist/extract/index.d.ts",
      "import": "./dist/extract/index.js"
    },
    "./lint": {
      "types": "./dist/lint/index.d.ts",
      "import": "./dist/lint/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "three": ">=0.160.0",
    "gsap": ">=3.12.0"
  },
  "peerDependenciesMeta": {
    "three": {
      "optional": true
    },
    "gsap": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/three": "^0.182.0",
    "gsap": "^3.14.2",
    "three": "^0.182.0",
    "tsup": "^8.5.0",
    "typescript": "^5",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
